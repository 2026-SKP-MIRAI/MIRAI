      "filename": "sample_resume.pdf",
      "description": "한국어 텍스트 기반 자기소개서 (정상 케이스)",
      "language": "ko",
      "has_text_layer": true,
      "page_count": 1,
      "approx_chars": 781,
      "file_size_category": "normal",
      "expected_output": {
        "status": 200,
        "ref": "mock_llm_response.json"
      }
    },
    {
      "id": "normal_en",
      "filename": "sample_resume_en.pdf",
