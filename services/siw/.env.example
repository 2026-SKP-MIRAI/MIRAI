# siw 서비스 환경변수 예시
# 실제 값은 .env.local에 설정 (이 파일은 커밋용 템플릿)

# ── 엔진 ────────────────────────────────────────────────
ENGINE_BASE_URL=http://localhost:8000

# ── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM Observability (optional — 미설정 시 로컬 파일 fallback) ──
S3_LOG_BUCKET=           # e.g. mirai-logs
S3_LOG_PREFIX=llm-events # S3 key prefix (default: llm-events)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── RAG (optional — Pipeline 2-2 배포 시 true로 설정) ───────────
# ENABLE_RAG=true
