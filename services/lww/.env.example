# lww 서비스 환경변수 예시
# 실제 값은 Vercel 대시보드 또는 .env.local에 설정 (이 파일은 커밋용 템플릿)

# ── 엔진 ────────────────────────────────────────────────
# Python FastAPI 엔진 서비스 베이스 URL
# 로컬: http://localhost:8000 / 프로덕션: 실제 엔진 서버 URL
ENGINE_BASE_URL=http://localhost:8000

# ── Supabase ────────────────────────────────────────────
# Supabase 프로젝트 URL (대시보드 → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (공개 가능 — RLS로 보호)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (서버 전용 — 절대 NEXT_PUBLIC_ 사용 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage 버킷명 (자소서 업로드 등)
SUPABASE_STORAGE_BUCKET=lww-uploads

# ── OAuth (Phase 1) ─────────────────────────────────────
# 카카오 OAuth
# 카카오 개발자 콘솔: https://developers.kakao.com
# redirect_uri: {NEXT_PUBLIC_SITE_URL}/api/auth/kakao/callback
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# 구글 OAuth
# Google Cloud Console: https://console.cloud.google.com
# redirect_uri: {NEXT_PUBLIC_SITE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── 사이트 URL ───────────────────────────────────────────
# 로컬: http://localhost:3000 / 프로덕션: https://lww.vercel.app (예시)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
