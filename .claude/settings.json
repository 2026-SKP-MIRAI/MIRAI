{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(mkdir:*)",
      "Glob",
      "Grep",
      "Read",
      "Edit",
      "Write",
      "AskUserQuestion",
      "WebSearch",
      "WebFetch",
      "MultiEdit",
      "NotebookEdit"
    ],
    "deny": ["Bash(sudo:*)", "Bash(: >:*)"]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/secret-filter.sh"
          }
        ]
      }
    ]
  }
}
